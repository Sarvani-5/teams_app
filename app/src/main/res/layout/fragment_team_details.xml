<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Meet the Visionaries"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/colorPrimary"
            android:gravity="center"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Together, we bring a blend of innovation, passion, and expertise to create an extraordinary cultural journey."
            android:textSize="18sp"
            android:textStyle="italic"
            android:textColor="@color/black"
            android:gravity="center"
            android:layout_marginBottom="20dp"/>

        <!-- Team Photo -->
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:src="@drawable/team_photo"
        android:contentDescription="Our Team"
        android:scaleType="centerCrop"
        android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Our team is a dynamic blend of passionate individuals, each bringing their unique expertise to the table. United by a shared goal, we aim to bridge the gap between technology and culture, allowing people to reconnect with Tamil Nadu’s vibrant heritage. With a deep appreciation for the state’s rich traditions, we are committed to using cutting-edge technology to create an immersive experience that brings the past to life for future generations. Together, we are not just building an app; we are building a platform that celebrates the soul of Tamil Nadu and its timeless stories."
            android:textSize="16sp"

            android:lineSpacingExtra="4dp"
            android:gravity="center"/>

    </LinearLayout>
</ScrollView>
